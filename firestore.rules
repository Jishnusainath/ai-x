rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public community speculations
    match /community_speculations/{speculationId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        // Allow liking (only incrementing or toggling likes)
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likesCount']) ||
        // Allow editing own post
        resource.data.authorId == request.auth.uid
      );
      allow delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }

    // User-specific data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
